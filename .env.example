VITE_API_BASE_URL=http://127.0.0.1:8000
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,https://ignite-forecast-iq.vercel.app
# Backend-only secret. Do not prefix with VITE_ and do not commit .env.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_TEMPERATURE=0.2
GEMINI_TIMEOUT_SECONDS=45
GEMINI_MAX_ATTEMPTS=3
GEMINI_RETRY_BACKOFF_SECONDS=1.5
GEMINI_MAX_OUTPUT_TOKENS=3072
SLOWAPI_DEFAULT_LIMITS=200/hour
LOG_LEVEL=INFO
