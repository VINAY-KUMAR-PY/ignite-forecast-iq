VITE_API_BASE_URL=http://127.0.0.1:8000
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173","http://localhost:4173","http://127.0.0.1:4173","http://localhost:3000","http://127.0.0.1:3000"]
# Backend-only secret. Do not prefix with VITE_ and do not commit .env.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_TEMPERATURE=0.2
GEMINI_TIMEOUT_SECONDS=45
GEMINI_MAX_ATTEMPTS=3
GEMINI_RETRY_BACKOFF_SECONDS=1.5
GEMINI_MAX_OUTPUT_TOKENS=1600
LOG_LEVEL=INFO
